<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookStore.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- ================================================================ -->
    <!-- NAVBAR - Thanh điều hướng chính -->
    <!-- ================================================================ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <!-- Logo/Brand -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book"></i> BookStore
            </a>

            <!-- Toggle Button cho Mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-controls="navbarMain"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu chính -->
            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Menu bên trái -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "active" : "")"
                           asp-controller="Book" asp-action="Index">
                            <i class="bi bi-book"></i> Sách
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                           asp-controller="Category" asp-action="Index">
                            <i class="bi bi-grid-3x3-gap"></i> Thể loại
                        </a>
                    </li>
                </ul>

                <!-- Menu bên phải -->
                <ul class="navbar-nav">
                    <!-- Tìm kiếm nhanh -->
                    <li class="nav-item me-2">
                        <form class="d-flex" asp-controller="Book" asp-action="Search" method="get">
                            <input class="form-control form-control-sm me-1" type="search" name="keyword"
                                   placeholder="Tìm kiếm sách..." aria-label="Search">
                            <button class="btn btn-light btn-sm" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>
                    </li>

                    <!-- Giỏ hàng (placeholder) -->
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-cart3 position-relative">
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    0
                                </span>
                            </i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ================================================================ -->
    <!-- NỘI DUNG CHÍNH -->
    <!-- ================================================================ -->
    <main>
        @RenderBody()
    </main>

    <!-- ================================================================ -->
    <!-- FOOTER - Chân trang -->
    <!-- ================================================================ -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <!-- Cột 1: Giới thiệu -->
                <div class="col-md-4 mb-3">
                    <h5>
                        <i class="bi bi-book"></i> BookStore
                    </h5>
                    <p class="text-muted small mb-0">
                        Cửa hàng sách trực tuyến hàng đầu Việt Nam.
                        Mang đến cho bạn những cuốn sách chất lượng với giá cả hợp lý.
                    </p>
                </div>

                <!-- Cột 2: Liên kết nhanh -->
                <div class="col-md-4 mb-3">
                    <h6>Liên kết nhanh</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">Trang chủ</a></li>
                        <li><a asp-controller="Book" asp-action="Index" class="text-muted text-decoration-none small">Sách</a></li>
                        <li><a asp-controller="Category" asp-action="Index" class="text-muted text-decoration-none small">Thể loại</a></li>
                    </ul>
                </div>

                <!-- Cột 3: Liên hệ -->
                <div class="col-md-4 mb-3">
                    <h6>Liên hệ</h6>
                    <ul class="list-unstyled text-muted small">
                        <li><i class="bi bi-geo-alt"></i> 123 Đường ABC, Quận 1, TP.HCM</li>
                        <li><i class="bi bi-telephone"></i> Hotline: 0123-456-789</li>
                        <li><i class="bi bi-envelope"></i> Email: contact@bookstore.com</li>
                    </ul>
                </div>
            </div>

            <!-- Copyright -->
            <hr class="bg-secondary">
            <p class="text-center text-muted small mb-0">
                &copy; @DateTime.Now.Year - BookStore - ASP.NET Core MVC & Entity Framework Core
            </p>
        </div>
    </footer>

    <!-- ================================================================ -->
    <!-- SCRIPTS -->
    <!-- ================================================================ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

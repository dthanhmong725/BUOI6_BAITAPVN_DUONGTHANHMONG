@* ================================================================
   VIEW: Views/Book/Details.cshtml
   Trang chi tiết sách - Thiết kế giống trang thương mại điện tử (Fahasa)
   ================================================================ *@

@model BookStore.Models.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";
}

@* ================================================================
   BREADCRUMB - ĐƯỜNG DẪN
   ================================================================ *@
<nav aria-label="breadcrumb" class="mt-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-house"></i> Trang chủ
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Book" asp-action="Index">Sách</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

@* ================================================================
   NỘI DUNG CHÍNH - CHI TIẾT SÁCH
   ================================================================ *@
<div class="container-fluid mt-4 mb-5">
    <div class="row">

        @* ================================================================
           CỘT TRÁI - HÌNH ẢNH SÁCH
           ================================================================ *@
        <div class="col-lg-5 col-md-6 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img src="@Model.Image" class="img-fluid rounded book-detail-image"
                             alt="@Model.Title" style="max-height: 500px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-center py-5 bg-light rounded">
                            <i class="bi bi-image text-muted" style="font-size: 8rem;"></i>
                            <p class="text-muted mt-2">Không có hình ảnh</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ================================================================
           CỘT PHẢI - THÔNG TIN SÁCH
           ================================================================ *@
        <div class="col-lg-7 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">

                    @* THỂ LOẠI *@
                    @if (Model.Category != null)
                    {
                        <span class="badge bg-info mb-3">
                            <i class="bi bi-tag"></i> @Model.Category.CategoryName
                        </span>
                    }

                    @* TIÊU ĐỀ SÁCH *@
                    <h2 class="book-title mb-3">@Model.Title</h2>

                    @* TÁC GIẢ *@
                    <p class="text-muted mb-2">
                        <i class="bi bi-person-fill"></i>
                        <strong>Tác giả:</strong> @Model.Author
                    </p>

                    @* MÔ TẢ *@
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mb-4">
                            <h5 class="text-secondary"><i class="bi bi-card-text"></i> Mô tả:</h5>
                            <p class="text-justify" style="line-height: 1.8;">@Model.Description</p>
                        </div>
                    }

                    @* GIÁ BÁN - NỔI BẬT *@
                    <div class="bg-light p-4 rounded mb-4">
                        <div class="d-flex align-items-center">
                            <div>
                                <span class="text-muted small">Giá bán:</span>
                                <h3 class="text-danger fw-bold mb-0 fs-1">
                                    @Model.Price.ToString("N0") <span class="fs-5">VNĐ</span>
                                </h3>
                            </div>
                        </div>
                    </div>

                    @* CÁC NÚT HÀNH ĐỘNG *@
                    <div class="d-grid gap-2 d-md-block mb-4">
                        <button class="btn btn-success btn-lg me-2 mb-2" type="button">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                        <button class="btn btn-danger btn-lg mb-2" type="button">
                            <i class="bi bi-lightning"></i> Mua ngay
                        </button>
                    </div>

                    @* THÔNG TIN BỔ SUNG *@
                    <div class="border-top pt-3">
                        <div class="row text-muted small">
                            <div class="col-6">
                                <p class="mb-1"><i class="bi bi-check-circle text-success"></i> Miễn phí vận chuyển cho đơn hàng từ 150.000đ</p>
                                <p class="mb-1"><i class="bi bi-check-circle text-success"></i> Giao hàng nhanh trong 24h</p>
                            </div>
                            <div class="col-6">
                                <p class="mb-1"><i class="bi bi-check-circle text-success"></i> Chính hãng 100%</p>
                                <p class="mb-1"><i class="bi bi-check-circle text-success"></i> Đổi trả trong 7 ngày</p>
                            </div>
                        </div>
                    </div>

                    @* CÁC NÚT QUẢN LÝ *@
                    <div class="border-top pt-3 mt-4">
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Sửa thông tin
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i> Xóa sách
                            </a>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ================================================================
   CSS CHO TRANG CHI TIẾT
   ================================================================ *@
<style>
    .book-title {
        color: #2c3e50;
        font-weight: 700;
        line-height: 1.3;
    }

    .book-detail-image {
        transition: transform 0.3s ease;
    }

    .book-detail-image:hover {
        transform: scale(1.02);
    }

    .btn-success {
        background-color: #27ae60;
        border-color: #27ae60;
    }

    .btn-success:hover {
        background-color: #219a52;
        border-color: #219a52;
    }

    .btn-danger {
        background-color: #e74c3c;
        border-color: #e74c3c;
    }

    .btn-danger:hover {
        background-color: #c0392b;
        border-color: #c0392b;
    }
</style>

@{
    ViewData["Title"] = "Trang Chủ";
}

@* ================================================================
   BANNER - HÌNH ẢNH GIỚI THIỆU
   ================================================================ *@
<div class="bg-primary text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="bi bi-book"></i> Chào Mừng Đến BookStore
                </h1>
                <p class="lead mb-0">
                    Khám phá kho tàng tri thức với hàng ngàn đầu sách chất lượng.
                    Đọc sách online, cập nhật kiến thức mới mỗi ngày.
                </p>
            </div>
            <div class="col-md-4 text-center">
                <i class="bi bi-book-half" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>
</div>

@* ================================================================
   SÁCH NỔI BẬT
   ================================================================ *@
<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h3 class="border-bottom pb-2">
                <i class="bi bi-star-fill text-warning"></i> Sách Nổi Bật
            </h3>
        </div>
    </div>

    @{
        // Lấy danh sách sách từ ViewBag
        var featuredBooks = ViewBag.FeaturedBooks as List<BookStore.Models.Book> ?? new List<BookStore.Models.Book>();
    }

    @if (featuredBooks.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
            @foreach (var book in featuredBooks)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm book-card">
                        @* HÌNH ẢNH *@
                        @if (!string.IsNullOrEmpty(book.Image))
                        {
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id">
                                <img src="@book.Image" class="card-img-top" alt="@book.Title"
                                     style="height: 200px; object-fit: cover;" />
                            </a>
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                                 style="height: 200px;">
                                <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                            </div>
                        }

                        <div class="card-body">
                            @if (book.Category != null)
                            {
                                <span class="badge bg-info mb-2">@book.Category.CategoryName</span>
                            }
                            <h6 class="card-title text-truncate">
                                <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id"
                                   class="text-decoration-none text-dark">
                                    @book.Title
                                </a>
                            </h6>
                            <p class="card-text text-muted small mb-2">
                                <i class="bi bi-person"></i> @book.Author
                            </p>
                            <p class="card-text fw-bold text-danger fs-5">
                                @book.Price.ToString("N0") VNĐ
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <div class="d-flex justify-content-between">
                                <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                <button class="btn btn-success btn-sm">
                                    <i class="bi bi-cart-plus"></i> Mua
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mb-5">
            <i class="bi bi-info-circle"></i> Chưa có cuốn sách nào. Hãy thêm sách mới!
            <br>
            <a asp-controller="Book" asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle"></i> Thêm sách mới
            </a>
        </div>
    }

    @* ================================================================
       THỂ LOẠI SÁCH
       ================================================================ *@
    <div class="row mb-4">
        <div class="col">
            <h3 class="border-bottom pb-2">
                <i class="bi bi-grid-3x3-gap text-primary"></i> Thể Loại Sách
            </h3>
        </div>
    </div>

    @{
        // Lấy danh sách thể loại từ ViewBag với kiểu đúng
        var categories = ViewBag.Categories as List<BookStore.Models.Category> ?? new List<BookStore.Models.Category>();
    }

    @if (categories.Any())
    {
        <div class="row g-4 mb-5">
            @foreach (var category in categories)
            {
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center shadow-sm h-100">
                        <div class="card-body">
                            <i class="bi bi-folder text-primary" style="font-size: 3rem;"></i>
                            <h5 class="card-title mt-2">@category.CategoryName</h5>
                            <p class="card-text text-muted">
                                @{
                                    // Đếm số sách, check null an toàn
                                    var bookCount = category.Books?.Count ?? 0;
                                }
                                <span class="badge bg-secondary">@bookCount cuốn sách</span>
                            </p>
                            <a asp-controller="Book" asp-action="FilterByCategory"
                               asp-route-categoryId="@category.CategoryId"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-arrow-right"></i> Xem sách
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mb-5">
            <i class="bi bi-info-circle"></i> Chưa có thể loại nào.
        </div>
    }
</div>

@* ================================================================
   CSS
   ================================================================ *@
<style>
    .book-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .book-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
</style>
